<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tournasys.controller.DashboardController"
            stylesheets="@../css/app.css"
            styleClass="root-container">

    <top>
        <fx:include fx:id="navbar" source="navbar.fxml"/>
    </top>

    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets top="30" left="30" right="30" bottom="30"/>
            </padding>

            <Label text="Dashboard" styleClass="page-title"/>
            <Label fx:id="subtitleLabel" text="Manage your tournaments efficiently." styleClass="page-subtitle"/>

            <VBox spacing="10" styleClass="card">
                <Label text="Quick Actions" styleClass="page-title"/>

                <Button fx:id="tournamentsButton" text="Create Tournament" onAction="#goToTournaments" styleClass="primary-button"/>
                <Button fx:id="teamsButton" text="Manage Teams" onAction="#goToTeams" styleClass="primary-button"/>
                <Button fx:id="matchesButton" text="Schedule Matches" onAction="#goToMatches" styleClass="primary-button"/>
                <Button fx:id="standingsButton" text="View Standings" onAction="#goToStandings" styleClass="primary-button"/>
                <Button fx:id="bracketButton" text="View Bracket" onAction="#goToBracket" styleClass="primary-button"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
