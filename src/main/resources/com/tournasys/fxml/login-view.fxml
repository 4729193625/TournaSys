<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.tournasys.controller.LoginController"
           stylesheets="@../css/app.css"
           styleClass="auth-root">

    <VBox alignment="CENTER"
          spacing="16"
          styleClass="auth-card"
          minWidth="380"
          prefWidth="380"
          maxWidth="380"
          minHeight="460"
          prefHeight="460"
          maxHeight="460">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <!-- LOGO -->
        <Label text="TournaSys" styleClass="auth-logo"/>

        <!-- TITLE -->
        <Label text="Log In" styleClass="auth-title"/>
        <Label text="Access your account." styleClass="auth-subtitle"/>

        <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="320">
            <Label text="Username" styleClass="form-label"/>
            <TextField fx:id="usernameField"
                       promptText="Enter username"
                       styleClass="auth-input"/>
        </VBox>

        <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="320">
            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter password"
                           styleClass="auth-input"/>
        </VBox>

        <VBox spacing="10" alignment="CENTER" maxWidth="320">
            <Button text="Log In"
                    onAction="#handleLogin"
                    maxWidth="320"
                    styleClass="primary-button"/>

            <Button text="Register"
                    onAction="#goToRegister"
                    maxWidth="320"
                    styleClass="secondary-button"/>
        </VBox>

    </VBox>

</StackPane>
