<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tournasys.controller.NavbarController"
            styleClass="topbar">

    <left>
        <HBox alignment="CENTER_LEFT" styleClass="nav-left">
            <Label text="TournaSys" styleClass="nav-title"/>
        </HBox>
    </left>

    <center>
        <StackPane>
            <HBox alignment="CENTER" spacing="0">

                <Button fx:id="dashboardButton"
                        text="Dashboard"
                        onAction="#goDashboard"
                        styleClass="nav-button"/>
                <Region styleClass="nav-divider"/>

                <Button fx:id="tournamentsButton"
                        text="Tournaments"
                        onAction="#goTournaments"
                        styleClass="nav-button"/>
                <Region styleClass="nav-divider"/>

                <Button fx:id="teamsButton"
                        text="Teams"
                        onAction="#goTeams"
                        styleClass="nav-button"/>
                <Region styleClass="nav-divider"/>

                <Button fx:id="matchesButton"
                        text="Matches"
                        onAction="#goMatches"
                        styleClass="nav-button"/>
                <Region styleClass="nav-divider"/>

                <Button fx:id="standingsButton"
                        text="Standings"
                        onAction="#goStandings"
                        styleClass="nav-button"/>
                <Region styleClass="nav-divider"/>

                <Button fx:id="bracketButton"
                        text="Bracket"
                        onAction="#goBracket"
                        styleClass="nav-button"/>

            </HBox>
        </StackPane>
    </center>

    <right>
        <HBox alignment="CENTER_RIGHT" styleClass="nav-right-group">
            <Button text="Logout" onAction="#handleLogout" styleClass="nav-button-logout"/>
        </HBox>
    </right>

</BorderPane>
